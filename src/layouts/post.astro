---
import { AppConfig } from '@/utils/AppConfig';
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import PostContent from '@/components/PostContent.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';
import Giscus from '@/components/Giscus.astro';
import { getPostNeighbors } from '@/utils/posts';
import { formatDate } from '@/utils/data.util';
import { topicSlug } from '@/utils/topics';

const { description } = AppConfig;

const { frontmatter } = Astro.props;

const slug = (Astro.url.pathname.split('/').pop() || Astro.url.pathname.split('/').slice(-2)[0]) || '';
const cleanSlug = slug.replace(/\/$/, '');
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://sudhir.is-a.dev';
const ogImageUrl = `${siteUrl}/og/${cleanSlug}.png`;
const postUrl = `${siteUrl}${Astro.url.pathname}`;
const publishedTime = new Date(frontmatter.pubDate).toISOString();
const modifiedTime = frontmatter.updatedDate
	? new Date(frontmatter.updatedDate).toISOString()
	: undefined;

const { newer, older } = await getPostNeighbors(cleanSlug);
const nextPost = older ?? newer;

const category = frontmatter.tags?.[0] as string | undefined;
const formattedDate = formatDate(frontmatter.pubDate);
const readTime = frontmatter.minutesRead?.trim() || 'Quick read';
---

<Base
	head={{
		title: `${frontmatter.title} | ${AppConfig.site_name}`,
		description: frontmatter.description || description,
		image: ogImageUrl,
		article: {
			publishedTime,
			modifiedTime,
			tags: frontmatter.tags
		}
	}}
>
	<script type="application/ld+json" is:inline set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BlogPosting",
		"headline": frontmatter.title,
		"description": frontmatter.description || description,
		"image": ogImageUrl,
		"datePublished": frontmatter.pubDate,
		"dateModified": frontmatter.updatedDate ?? frontmatter.pubDate,
		"author": {
			"@type": "Person",
			"name": frontmatter.author || "Sudhir",
			"url": `${siteUrl}/about`,
			"sameAs": ["https://github.com/sudhir45", "https://linkedin.com/in/dsudhir"]
		},
		"publisher": {
			"@type": "Person",
			"name": "Sudhir"
		},
		"mainEntityOfPage": {
			"@type": "WebPage",
			"@id": postUrl
		},
		"keywords": frontmatter.tags?.join(", ") || ""
	})} />
	<ReadingProgress />
	<Section>
		<!-- Header -->
		<header class="mx-auto max-w-[800px] pb-4 pt-10 md:pt-14">
			{category && (
				<a
					href={`/tags/${topicSlug(category)}`}
					class="eyebrow-amber mb-5 inline-block transition-opacity hover:opacity-70"
				>
					{category}
				</a>
			)}
			<h1
				transition:name={cleanSlug ? `post-title-${cleanSlug}` : undefined}
				class="font-display text-fg text-[2rem] font-medium leading-[1.1] tracking-[-0.025em] text-balance md:text-[2.75rem]"
			>
				{frontmatter.title}
			</h1>
			<div class="meta-mono mt-6 flex flex-wrap items-center gap-3">
				<time datetime={String(frontmatter.pubDate)}>{formattedDate}</time>
				<span aria-hidden="true">·</span>
				<span>{readTime}</span>
			</div>
		</header>

		<PostContent><slot /></PostContent>

		{nextPost && (
			<div class="border-frame mx-auto mt-4 max-w-[800px] border-t pt-7">
				<div class="meta-mono mb-3.5">Next</div>
				<a
					href={nextPost.url}
					class="row-link flex items-baseline justify-between gap-5"
				>
					<span class="row-title font-display text-fg text-[19px] font-medium leading-[1.3] tracking-[-0.015em] transition-colors md:text-[22px]">
						{nextPost.data.title}
					</span>
					<span class="text-accent whitespace-nowrap text-[13px] font-medium">
						Read <span class="row-arrow">→</span>
					</span>
				</a>
			</div>
		)}

		<div class="mx-auto mt-16 max-w-[800px]">
			<Giscus />
		</div>
	</Section>

	<script>
		document.addEventListener('astro:page-load', () => {

			const initZoom = () => {
				const isDark = document.documentElement.classList.contains('dark');
				if ((window as any).mediumZoom) {
					const zoom = (window as any).mediumZoom('img:not(.no-zoom)', {
						margin: 24,
						background: isDark ? '#1a1714' : '#faf9f7',
					});
					return zoom;
				} else {
					const script = document.createElement('script');
					script.src = 'https://cdn.jsdelivr.net/npm/medium-zoom@1.1.0/dist/medium-zoom.min.js';
					script.onload = () => {
						(window as any).mediumZoom('article img:not(.no-zoom), .prose img:not(.no-zoom)', {
							margin: 24,
							background: isDark ? '#1a1714' : '#faf9f7',
						});
					};
					document.head.appendChild(script);
				}
			};
			initZoom();

			const blocks = document.querySelectorAll('pre');
			blocks.forEach((block) => {
				if (block.querySelector('.copy-button')) return;
				
				const parent = block.parentNode as HTMLElement;
				if (!parent.classList.contains('relative')) {
					const wrapper = document.createElement('div');
					wrapper.className = 'relative group rounded-lg overflow-hidden';
					parent.insertBefore(wrapper, block);
					wrapper.appendChild(block);
				} else {
					parent.classList.add('group');
				}

				const btn = document.createElement('button');
				btn.className = 'copy-button absolute top-3 right-3 p-1.5 rounded bg-zinc-700/50 text-zinc-400 opacity-0 transition-all hover:bg-zinc-600 hover:text-white group-hover:opacity-100 focus:opacity-100';
				btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
				btn.setAttribute('aria-label', 'Copy code');
				
				block.appendChild(btn);

				btn.addEventListener('click', async () => {
					const code = block.querySelector('code');
					if (!code) return;
					await navigator.clipboard.writeText(code.innerText);
					btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-400"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
					setTimeout(() => {
						btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
					}, 2000);
				});
			});

		});
	</script>
</Base>
