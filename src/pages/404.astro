---
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import { getAllPosts } from '@/utils/posts';

const recentPosts = (await getAllPosts())
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 3);

const monthYear = (date: Date) =>
	date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---

<Base
	head={{
		title: 'Page not found | Sudhir',
		description: 'HTTP 404 - this page does not exist or has moved.'
	}}
>
	<Section>
		<div class="animate-fade-up pt-14 md:pt-20">
			<p class="meta-mono uppercase tracking-[0.06em]">HTTP 404 · content not found</p>
			<h1
				class="font-display text-fg mt-4 text-[2.25rem] font-medium leading-[1.08] tracking-[-0.025em] md:text-[2.75rem]"
			>
				This page doesn't exist.
			</h1>
			<p class="text-muted mt-4 max-w-[540px] text-[17px] leading-[1.65]">
				Either it never existed, or it moved without leaving a redirect. No exploit here - just a
				bad link.
			</p>

			<div class="mt-7 flex flex-wrap items-baseline gap-x-7 gap-y-3 text-sm font-medium">
				<a href="/" class="text-accent transition-opacity hover:opacity-70">← Back home</a>
				<a href="/posts" class="text-faint hover:text-fg transition-colors">Browse all posts</a>
				<span class="meta-mono hidden sm:inline">or press Ctrl K to search</span>
			</div>
		</div>

		<!-- Recent writing, same pattern as the home list -->
		<div class="animate-fade-up mt-16 pb-16">
			<div class="border-line-strong flex items-baseline justify-between border-b pb-4">
				<h2 class="font-display text-fg text-sm font-semibold">Recent writing</h2>
				<a href="/posts" class="text-subtle hover:text-fg text-[13px] font-medium transition-colors">
					All posts
				</a>
			</div>

			{
				recentPosts.map((post, i) => (
					<a
						href={post.url}
						class:list={[
							'row-link grid grid-cols-[64px_1fr] items-baseline gap-x-5 gap-y-1 py-5 sm:grid-cols-[96px_1fr_auto] sm:gap-6',
							i < recentPosts.length - 1 && 'border-line border-b'
						]}
					>
						<span class="meta-mono">{monthYear(post.data.pubDate)}</span>
						<span class="row-title font-display text-fg text-[19px] font-medium leading-[1.3] tracking-[-0.01em] transition-colors">
							{post.data.title}
						</span>
						<span class="text-faint hidden text-[13px] font-medium sm:block">Read →</span>
					</a>
				))
			}
		</div>
	</Section>
</Base>
