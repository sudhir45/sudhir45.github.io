---
import { AppConfig } from '@/utils/AppConfig';
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import CyberdleGame from '@/components/cyberdle/Cyberdle';

const title = `Cyberdle | ${AppConfig.site_name}`;
const description =
	'A daily security-themed word puzzle. Guess the five-letter cyber term in six tries - a fresh word every day.';
---

<Base head={{ title, description }}>
	<Section>
		<div class="animate-fade-up pt-10 md:pt-14">
			<p class="eyebrow-amber">Daily puzzle</p>
			<h1
				class="font-display text-fg mt-3.5 text-[2.25rem] font-medium leading-[1.08] tracking-[-0.025em] md:text-[2.75rem]"
			>
				Cyberdle
			</h1>
			<p class="text-muted mt-4 max-w-[960px] text-[17px] leading-[1.65]">
				Guess the five-letter security term in six tries. Green is the right spot, amber the wrong
				one. A new word at midnight IST.
			</p>
		</div>

		<CyberdleGame client:only="react">
			<div slot="fallback" class="meta-mono py-16 text-center">Loading puzzle…</div>
		</CyberdleGame>
	</Section>
</Base>
