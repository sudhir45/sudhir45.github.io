---
import { AppConfig } from '@/utils/AppConfig';
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import PresentationCard from '@/components/PresentationCard.astro';
import presentations from '@/data/presentations.json';

const title = `Presentations | ${AppConfig.site_name}`;
const description = 'Browse my collection of security presentations and talks.';
---

<Base head={{ title, description }}>
	<Section>
		<div class="py-8">
			
			<header class="border-line mb-10 border-b pb-6">
				<p class="eyebrow eyebrow-tick mb-3">Slide Decks</p>
				<h1 class="font-display text-fg mb-3 text-3xl font-semibold tracking-tight md:text-4xl">
					Talks
				</h1>
				<p class="text-muted max-w-2xl">
					Browse my collection of security presentations and talks.
				</p>
			</header>

			
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{presentations.map((pres) => (
					<PresentationCard 
						slug={pres.slug}
						title={pres.title}
						description={pres.description}
						thumbnail={pres.thumbnail}
						slideCount={pres.slideCount}
						category={pres.category}
					/>
				))}
			</div>

			{presentations.length === 0 && (
				<div class="border-line bg-surface rounded-xl border py-16 text-center">
					<p class="text-muted">No presentations available yet.</p>
				</div>
			)}
		</div>
	</Section>
</Base>
