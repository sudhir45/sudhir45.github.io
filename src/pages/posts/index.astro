---
import { AppConfig } from '@/utils/AppConfig';
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import PostRow from '@/components/PostRow.astro';
import Heading from '@/components/Heading.astro';
import { getAllPosts } from '@/utils/posts';

const title = `All Posts | ${AppConfig.site_name}`;
const description =
	'Practical writing on security architecture, firewall policy, compliance, and network security.';

const allPosts = await getAllPosts();
---

<Base head={{ title, description }}>
	<Section>
		<Heading title="All Posts" eyebrow="Archive" />
		<div class="border-line -mx-4 border-t md:-mx-6">
			{allPosts.map((post: any) => <PostRow post={post} />)}
		</div>
	</Section>
</Base>
