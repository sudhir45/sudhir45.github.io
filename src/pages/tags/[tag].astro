---
import Section from '@/components/Section.astro';
import PostRow from '@/components/PostRow.astro';
import Base from '@/layouts/Base.astro';
import { AppConfig } from '@/utils/AppConfig';
import { getAllPosts, type SitePost } from '@/utils/posts';

export async function getStaticPaths(): Promise<any> {
	const allPosts = await getAllPosts();
	const allTags = new Set(allPosts.flatMap((post) => post.data.tags));

	return [...allTags].map((tag) => {
		const filteredPosts = allPosts.filter((post) => post.data.tags.includes(tag));

		return {
			params: { tag: tag },
			props: {
				tag,
				posts: filteredPosts
			}
		};
	});
}

interface Props {
	tag: string;
	posts: SitePost[];
}

const { tag, posts } = Astro.props;
const title = AppConfig.title;
const description = AppConfig.description;
---

<Base head={{ title, description }}>
	<Section>
		<header class="border-line mb-10 border-b pb-6">
			<div class="flex items-end justify-between gap-4">
				<div>
					<p class="eyebrow eyebrow-tick mb-3">Tag</p>
					<h1 class="font-display text-fg text-3xl font-semibold tracking-tight md:text-4xl">
						<span class="text-faint">#</span>{tag}
					</h1>
					<p class="text-muted mt-3 font-mono text-sm">
						{posts.length} {posts.length === 1 ? 'post' : 'posts'}
					</p>
				</div>
				<a
					href="/tags"
					class="group border-line bg-surface text-muted hover:border-accent/40 hover:text-accent inline-flex items-center gap-1.5 rounded-lg border px-3 py-2 text-sm font-medium transition-all"
				>
					<svg class="h-4 w-4 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
					</svg>
					All tags
				</a>
			</div>
		</header>
		<div class="border-line -mx-4 border-t md:-mx-6">
			{posts.map((post) => <PostRow post={post} />)}
		</div>
	</Section>
</Base>
