---
import Section from '@/components/Section.astro';
import Base from '@/layouts/Base.astro';
import { AppConfig } from '@/utils/AppConfig';
import { getAllPosts, type SitePost } from '@/utils/posts';
import { TOPICS, getTopicBySlug, type Topic } from '@/utils/topics';

export async function getStaticPaths(): Promise<any> {
	const allPosts = await getAllPosts();
	return TOPICS.map((topic) => ({
		params: { tag: topic.slug },
		props: {
			topic,
			posts: allPosts.filter((post) => post.data.tags.includes(topic.name))
		}
	}));
}

interface Props {
	topic: Topic;
	posts: SitePost[];
}

const { topic, posts } = Astro.props as Props;
const title = `${topic.name} | ${AppConfig.site_name}`;
const description = topic.description;

const shortMeta = (post: SitePost) => {
	const date = post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
	const read = (post.data.minutesRead ?? '').replace(/\s*read$/i, '').trim();
	return read ? `${date} · ${read}` : date;
};

// Guard against a stale/unknown slug during dev.
const resolved = getTopicBySlug(topic.slug);
---

<Base head={{ title, description }}>
	<Section>
		<div class="pb-9 pt-10 md:pt-14">
			<a href="/tags" class="eyebrow-amber mb-5 inline-block transition-opacity hover:opacity-70">
				← Topics
			</a>
			<h1 class="font-display text-fg text-[2.25rem] font-medium leading-[1.08] tracking-[-0.025em] md:text-[2.75rem]">
				{resolved?.name ?? topic.name}
			</h1>
			<p class="text-muted mt-4 max-w-[560px] text-[17px] leading-[1.65]">{topic.description}</p>
			<p class="meta-mono mt-3">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
		</div>

		<div class="border-t border-[color:var(--line-strong)] pb-16">
			{
				posts.map((post) => (
					<a
						href={post.url}
						class="row-link border-line grid grid-cols-[1fr_auto] items-baseline gap-5 border-b py-5"
					>
						<span class="row-title font-display text-fg text-[19px] font-medium leading-[1.3] tracking-[-0.01em] transition-colors md:text-[21px]">
							{post.data.title}
						</span>
						<span class="meta-mono whitespace-nowrap">{shortMeta(post)}</span>
					</a>
				))
			}
		</div>
	</Section>
</Base>
