---
import Heading from '@/components/Heading.astro';
import Section from '@/components/Section.astro';
import Base from '@/layouts/Base.astro';
import { AppConfig } from '@/utils/AppConfig';
import { getTagCounts } from '@/utils/posts';

const { title } = AppConfig;
const { description } = AppConfig;

const tagMap: Record<string, number> = await getTagCounts();
---

<Base head={{ title, description }}>
	<Section>
		<Heading title="All Tags" eyebrow="Index" subtitle="Browse posts by topic." />
		<div class="flex flex-wrap gap-3">
			{
				Object.entries(tagMap).map(([tag, count]) => (
					<a
						href={`/tags/${tag}`}
						class="group border-line bg-surface text-muted hover:border-accent/40 hover:text-fg relative flex items-center gap-2 rounded-lg border px-4 py-2.5 font-mono text-sm transition-all hover:-translate-y-0.5"
					>
						<span><span class="text-faint">#</span>{tag}</span>
						<span class="bg-surface-2 text-faint group-hover:text-accent rounded px-1.5 py-0.5 text-xs font-semibold transition-colors">
							{count}
						</span>
					</a>
				))
			}
		</div>
	</Section>
</Base>
