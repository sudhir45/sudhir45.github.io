---
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import { AppConfig } from '@/utils/AppConfig';
import { getTopicsWithCounts } from '@/utils/topics';

const title = `Topics | ${AppConfig.site_name}`;
const description =
	'The threads that run through the writing: security architecture, network security, compliance, and more.';

const topics = await getTopicsWithCounts();
const threadCount = topics.length;
const numberWords = ['zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine'];
const threadWord = numberWords[threadCount] ?? String(threadCount);
const threadWordCap = threadWord.charAt(0).toUpperCase() + threadWord.slice(1);
---

<Base head={{ title, description }}>
	<Section>
		<div class="pb-9 pt-10 md:pt-14">
			<h1 class="font-display text-fg text-[2.25rem] font-medium leading-[1.08] tracking-[-0.025em] md:text-[2.75rem]">
				Topics
			</h1>
			<p class="text-muted mt-4 max-w-[520px] text-[17px] leading-[1.65]">
				{threadWordCap} threads run through everything here. Pick one to follow.
			</p>
		</div>

		<div class="pb-16">
			{
				topics.map((topic, i) => (
					<a
						href={`/tags/${topic.slug}`}
						class:list={[
							'row-link grid grid-cols-[1fr_auto] items-baseline gap-x-6 gap-y-1 py-6 sm:grid-cols-[minmax(200px,auto)_1fr_auto]',
							i === 0 ? 'border-t border-[color:var(--line-strong)]' : 'border-line border-t'
						]}
					>
						<span class="row-title font-display text-fg text-[22px] font-medium tracking-[-0.01em] transition-colors sm:min-w-[230px] sm:text-[24px]">
							{topic.name}
						</span>
						<span class="text-faint order-3 col-span-2 text-[15px] leading-[1.5] sm:order-none sm:col-span-1">
							{topic.description}
						</span>
						<span
							class="meta-mono justify-self-end whitespace-nowrap"
							style={i === 0 ? 'color:var(--accent)' : undefined}
						>
							{topic.count} {topic.count === 1 ? 'post' : 'posts'}
						</span>
					</a>
				))
			}
		</div>
	</Section>
</Base>
