---
import Section from './Section.astro';
import presentations from '@/data/presentations.json';

const deckCount = presentations.length;
const slideCount = presentations.reduce((sum, p) => sum + (p.slideCount ?? 0), 0);
---

<Section>
	<div class="animate-fade-up stagger-5 mb-2 mt-8">
		<div class="mb-6 flex items-center gap-3">
			<span class="eyebrow eyebrow-tick">Beyond the blog</span>
			<div class="bg-line h-px flex-1"></div>
		</div>

		<div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
			<a
				href="/presentations"
				class="group bg-surface border-line hover:border-accent/40 relative flex flex-col rounded-xl border p-6 transition-all duration-200 hover:-translate-y-0.5"
			>
				<span class="eyebrow">Talks</span>
				<h3 class="font-display text-fg group-hover:text-accent mt-3 text-lg font-semibold tracking-tight transition-colors">
					Conference talks &amp; slide decks
				</h3>
				<p class="text-muted mt-2 text-sm leading-relaxed">
					Conference talks on firewall policy management and network security automation.
				</p>
				<span class="text-faint mt-auto flex items-center justify-between pt-5 font-mono text-xs tabular-nums">
					<span>{deckCount} {deckCount === 1 ? 'deck' : 'decks'} · {slideCount} slides</span>
					<span class="text-accent inline-flex items-center gap-1 transition-all group-hover:gap-2">
						Browse
						<svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
						</svg>
					</span>
				</span>
			</a>

			<a
				href="/cyberdle"
				class="group bg-surface border-line hover:border-accent/40 relative flex flex-col rounded-xl border p-6 transition-all duration-200 hover:-translate-y-0.5"
			>
				<span class="eyebrow">Daily puzzle</span>
				<h3 class="font-display text-fg group-hover:text-accent mt-3 text-lg font-semibold tracking-tight transition-colors">
					Cyberdle
				</h3>
				<p class="text-muted mt-2 text-sm leading-relaxed">
					Guess the five-letter security term in six tries. A new word every day at midnight IST.
				</p>
				<span class="text-faint mt-auto flex items-center justify-between pt-5 font-mono text-xs">
					<span aria-hidden="true" class="flex gap-1">
						<span class="border-line bg-surface-2 inline-flex h-5 w-5 items-center justify-center rounded border">C</span>
						<span class="inline-flex h-5 w-5 items-center justify-center rounded bg-green-600/80 text-white">Y</span>
						<span class="border-line bg-surface-2 inline-flex h-5 w-5 items-center justify-center rounded border">B</span>
						<span class="bg-accent-strong text-accent-contrast inline-flex h-5 w-5 items-center justify-center rounded">E</span>
						<span class="border-line bg-surface-2 inline-flex h-5 w-5 items-center justify-center rounded border">R</span>
					</span>
					<span class="text-accent inline-flex items-center gap-1 transition-all group-hover:gap-2">
						Play
						<svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
						</svg>
					</span>
				</span>
			</a>
		</div>
	</div>
</Section>
