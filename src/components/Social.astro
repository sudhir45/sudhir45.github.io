---
interface Props {
	href: string;
}

const { href } = Astro.props;
---

<a
	href={href}
	target="_blank"
	rel="noopener noreferrer"
	class="border-line bg-surface text-muted hover:border-accent/50 hover:text-accent flex h-10 w-10 items-center justify-center rounded-lg border transition-all duration-200"
>
	<slot />
</a>
