---
import Section from './Section.astro';
import Card from './Card.astro';
import type { SitePost } from '@/utils/posts';

interface Props {
	posts: SitePost[];
}

const { posts } = Astro.props;
---

<Section>
	<div class="animate-fade-up stagger-4 mb-6 mt-8">
		<div class="flex items-center justify-between mb-6">
			<div class="flex items-center gap-2.5">
				<span class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-zinc-400 dark:text-zinc-500">Latest</span>
				<div class="h-px w-16 bg-zinc-200/70 dark:bg-zinc-800/70"></div>
			</div>
			<a href="/posts" class="group flex items-center gap-1 text-sm font-medium text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-500 dark:hover:text-zinc-100">
				<span class="link-underline">All posts</span>
				<svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
			</a>
		</div>
		<div class="grid grid-cols-1 gap-5 md:grid-cols-3">
			{
				posts.map((post: any, index: number) => (
					<div class={`animate-fade-up stagger-${index + 4}`}>
						<Card post={post} />
					</div>
				))
			}
		</div>
	</div>
</Section>
