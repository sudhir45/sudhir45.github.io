---
import Section from './Section.astro';
import Card from './Card.astro';
import type { SitePost } from '@/utils/posts';

interface Props {
	posts: SitePost[];
}

const { posts } = Astro.props;
---

<Section>
	<div class="animate-fade-up stagger-4 mb-6 mt-8">
		<div class="mb-6 flex items-center justify-between gap-4">
			<div class="flex items-center gap-3">
				<span class="eyebrow eyebrow-tick">Latest</span>
				<div class="bg-line h-px w-16"></div>
			</div>
			<a href="/posts" class="group text-muted hover:text-accent flex items-center gap-1 text-sm font-medium transition-colors">
				<span class="link-underline">All posts</span>
				<svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
			</a>
		</div>
		<div class="grid grid-cols-1 gap-5 md:grid-cols-3">
			{
				posts.map((post: any, index: number) => (
					<div class={`animate-fade-up stagger-${index + 4}`}>
						<Card post={post} />
					</div>
				))
			}
		</div>
	</div>
</Section>
