---
import Tag from './Tag.astro';
import { topicSlug } from '@/utils/topics';

interface Props {
	tags: string[];
	withHref?: boolean;
}

const { tags, withHref } = Astro.props;
---

<div class="flex flex-wrap gap-2">
	{
		tags.map((tag: string) => {
			const element = <Tag tag={tag} withHref={withHref} />;
			return withHref ? <a href={`/tags/${topicSlug(tag)}`}>{element}</a> : element;
		})
	}
</div>
