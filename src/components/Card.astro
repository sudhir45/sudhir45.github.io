---
import { formatDate } from '@/utils/data.util';
import PinnedBadge from './PinnedBadge.astro';

interface Props {
	post: any;
}

const { post } = Astro.props;
const metadata = post.data ?? post.frontmatter;
const postUrl = post.url ?? (post.slug ? `/posts/${post.slug}` : '#');
const slug = post.slug ?? postUrl.replace(/\/$/, '').split('/').pop();
const isPinned = metadata.isPinned === true;
---

<a
	href={postUrl}
	class="group block h-full focus:outline-none"
	aria-label={`Read post: ${metadata.title}`}
>
	<div
		class="border-line bg-surface hover:border-accent/40 relative flex h-full flex-col overflow-hidden rounded-xl border p-5 transition-all duration-200 hover:-translate-y-0.5"
	>
		<span class="bg-accent-strong absolute inset-x-0 top-0 h-px scale-x-0 transition-transform duration-300 group-hover:scale-x-100"></span>

		<div class="flex flex-auto flex-col">
			<div class="text-faint mb-3 flex items-center justify-between gap-2 font-mono text-[0.7rem]">
				<div class="flex items-center gap-2">
					{isPinned && <PinnedBadge size="sm" />}
					<time>{formatDate(metadata.pubDate)}</time>
				</div>
				<span>{metadata.minutesRead ?? 'Quick read'}</span>
			</div>

			<h3
				transition:name={slug ? `post-title-${slug}` : undefined}
				class="font-display text-fg group-hover:text-accent mb-2 text-[1.1rem] font-semibold leading-snug tracking-tight transition-colors"
			>
				{metadata.title}
			</h3>

			<p class="text-muted mb-0 line-clamp-2 text-[0.85rem] leading-relaxed">
				{metadata.excerpt}
			</p>
		</div>
	</div>
</a>
