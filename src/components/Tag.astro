---
interface Props {
	tag: string;
	withHref?: boolean;
}

const { tag, withHref } = Astro.props;
---

<span
	class={`border-line bg-surface text-muted inline-flex items-center rounded-md border px-2 py-0.5 font-mono text-[11px] tracking-wide transition-colors ${
		withHref ? 'hover:border-accent/40 hover:text-accent' : ''
	}`}
>
	<span class="text-faint">#</span>{tag}
</span>
