---
import PinIcon from './PinIcon.astro';

interface Props {
	size?: 'sm' | 'md' | 'lg';
	class?: string;
}

const { size = 'md', class: className = '' } = Astro.props;

const badgeSizeClasses = {
	sm: 'px-2 py-0.5 text-[0.65rem]',
	md: 'px-2.5 py-1 text-xs',
	lg: 'px-3 py-1.5 text-sm'
};

const badgeSize = badgeSizeClasses[size];
---

<span
	class={`border-accent/30 bg-accent/10 text-accent inline-flex items-center gap-1 rounded-md border font-mono font-medium uppercase tracking-wide ${badgeSize} ${className}`}
>
	<PinIcon size={size} />
	<span>Pinned</span>
</span>
