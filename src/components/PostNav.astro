---
import type { SitePost } from '@/utils/posts';

interface Props {
	newer?: SitePost | undefined;
	older?: SitePost | undefined;
}

const { newer, older } = Astro.props;
---

{
	(newer || older) && (
		<nav aria-label="Post navigation" class="mb-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
			{newer ? (
				<a
					href={newer.url}
					class="group bg-surface border-line hover:border-accent/40 rounded-xl border p-4 transition-colors"
				>
					<span class="text-faint mb-1.5 flex items-center gap-1.5 font-mono text-xs uppercase tracking-wider">
						<svg class="h-3 w-3 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
						</svg>
						Newer post
					</span>
					<span class="font-display text-fg group-hover:text-accent block text-sm font-semibold leading-snug tracking-tight transition-colors">
						{newer.data.title}
					</span>
				</a>
			) : (
				<span aria-hidden="true" class="hidden sm:block" />
			)}
			{older && (
				<a
					href={older.url}
					class="group bg-surface border-line hover:border-accent/40 rounded-xl border p-4 text-right transition-colors"
				>
					<span class="text-faint mb-1.5 flex items-center justify-end gap-1.5 font-mono text-xs uppercase tracking-wider">
						Older post
						<svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
						</svg>
					</span>
					<span class="font-display text-fg group-hover:text-accent block text-sm font-semibold leading-snug tracking-tight transition-colors">
						{older.data.title}
					</span>
				</a>
			)}
		</nav>
	)
}
