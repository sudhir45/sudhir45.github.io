---
import type { SitePost } from '@/utils/posts';

interface Props {
	posts: SitePost[];
}

const { posts } = Astro.props;

const formatShortDate = (date: Date) =>
	date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

{
	posts.length > 0 && (
		<section class="mb-10">
			<div class="mb-5 flex items-center gap-3">
				<span class="eyebrow eyebrow-tick">Related reading</span>
				<div class="bg-line h-px flex-1" />
			</div>
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
				{posts.map((post) => (
					<a
						href={post.url}
						class="group bg-surface border-line hover:border-accent/40 flex flex-col rounded-xl border p-4 transition-all duration-200 hover:-translate-y-0.5"
					>
						<h3 class="font-display text-fg group-hover:text-accent text-sm font-semibold leading-snug tracking-tight transition-colors">
							{post.data.title}
						</h3>
						<span class="text-faint mt-auto flex items-center gap-2 pt-3 font-mono text-xs tabular-nums">
							<time datetime={post.data.pubDate.toISOString().slice(0, 10)}>
								{formatShortDate(post.data.pubDate)}
							</time>
							<span aria-hidden="true">·</span>
							<span>{post.data.minutesRead ?? 'Quick read'}</span>
						</span>
					</a>
				))}
			</div>
		</section>
	)
}
