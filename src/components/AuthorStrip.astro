---
import { Image } from 'astro:assets';
import { SOCIALS } from '@/utils/AppConfig';
import avatar from '@/assets/images/avatar.png';

interface Props {
	author: string;
}

const { author } = Astro.props;
const trustLinks = SOCIALS.filter((social) => ['GitHub', 'LinkedIn', 'Email'].includes(social.name));
---

<section class="border-line bg-surface relative mb-10 overflow-hidden rounded-2xl border p-6">
	<span class="bg-accent-strong absolute inset-y-0 left-0 w-[3px]"></span>
	<div class="flex items-start gap-5">
		<Image
			src={avatar}
			alt={`Portrait of ${author}`}
			width={128}
			format="webp"
			quality={82}
			loading="lazy"
			class="border-line bg-surface-2 h-14 w-14 shrink-0 rounded-full border object-cover object-top sm:h-16 sm:w-16"
		/>
		<div class="min-w-0">
			<p class="eyebrow eyebrow-tick mb-1.5">About the author</p>
			<h2 class="font-display text-fg text-xl font-semibold tracking-tight">{author}</h2>
			<p class="text-muted mt-2 max-w-3xl text-sm leading-relaxed">
				CISSP-certified security professional at Infosys. Writes about security architecture,
				compliance, tooling, and lessons from real-world defensive work.
			</p>
			<div class="mt-4 flex flex-wrap items-center gap-2">
				{trustLinks.map((social) => (
					<a
						href={social.url}
						target={social.url.startsWith('http') ? '_blank' : undefined}
						rel={social.url.startsWith('http') ? 'noopener noreferrer' : undefined}
						class="border-line bg-bg text-muted hover:border-accent/40 hover:text-accent rounded-lg border px-3 py-1.5 text-sm font-medium transition-colors"
					>
						{social.name}
					</a>
				))}
			</div>
		</div>
	</div>
</section>
