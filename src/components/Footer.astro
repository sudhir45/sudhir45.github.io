---
import Section from './Section.astro';
import { SOCIALS } from '@/utils/AppConfig';

const year = new Date();
---

<Section>
	<footer class="mt-20 border-line border-t pb-12 pt-10">
		<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3">
			<div class="flex flex-col gap-3">
				<h3 class="text-faint mb-1 text-xs font-medium uppercase tracking-[0.14em]">Navigation</h3>
				<a class="text-muted hover:text-fg text-sm transition-colors" href="/">Home</a>
				<a class="text-muted hover:text-fg text-sm transition-colors" href="/posts">Writing</a>
				<a class="text-muted hover:text-fg text-sm transition-colors" href="/about">About</a>
				<a class="text-muted hover:text-fg text-sm transition-colors" href="/presentations">Talks</a>
			</div>

			<div class="flex flex-col gap-3">
				<h3 class="text-faint mb-1 text-xs font-medium uppercase tracking-[0.14em]">Find Me</h3>
				{SOCIALS.map((social: any) => (
					<a class="text-muted hover:text-fg text-sm transition-colors" href={social.url} target="_blank" rel="noopener noreferrer">{social.name}</a>
				))}
			</div>

			<div class="flex flex-col gap-3">
				<h3 class="text-faint mb-1 text-xs font-medium uppercase tracking-[0.14em]">Meta</h3>
				<a class="text-muted hover:text-fg text-sm transition-colors" href="/tags">Topics</a>
				<a class="text-muted hover:text-fg text-sm transition-colors" href="/cyberdle">Cyberdle</a>
				<a class="text-muted hover:text-fg text-sm transition-colors" href="/rss.xml">RSS Feed</a>
				<a class="text-muted hover:text-fg text-sm transition-colors" href="/imprint">Imprint</a>
			</div>
		</div>

		<div class="border-line mt-12 flex flex-col items-center justify-between border-t pt-6 sm:flex-row">
			<p class="text-muted text-sm">
				© {year.getFullYear()} <a class="text-fg hover:text-accent focus:text-accent font-medium outline-none transition-colors focus:underline" href="https://sudhir.is-a.dev" target="_blank" rel="noopener noreferrer">Sudhir</a>. All rights reserved.
			</p>
			<p class="meta-mono mt-3 sm:mt-0">
				Information Security · Mumbai, India
			</p>
		</div>
	</footer>
</Section>
