---
import Section from './Section.astro';
import { SOCIALS } from '@/utils/AppConfig';

const year = new Date().getFullYear();

const navLinks = [
	{ href: '/posts', label: 'Writing' },
	{ href: '/about', label: 'About' },
	{ href: '/presentations', label: 'Talks' },
	{ href: '/tags', label: 'Topics' },
	{ href: '/cyberdle', label: 'Cyberdle' },
	{ href: '/rss.xml', label: 'RSS' },
	{ href: '/imprint', label: 'Imprint' }
];
---

<Section>
	<footer class="border-line border-t pb-10 pt-8">
		<div class="flex flex-wrap items-baseline justify-between gap-x-10 gap-y-4">
			<nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm" aria-label="Footer">
				{
					navLinks.map(({ href, label }) => (
						<a class="text-muted hover:text-fg transition-colors" href={href}>
							{label}
						</a>
					))
				}
			</nav>
			<div class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
				{
					SOCIALS.map((social: { name: string; url: string }) => (
						<a
							class="text-muted hover:text-fg transition-colors"
							href={social.url}
							target="_blank"
							rel="noopener noreferrer"
						>
							{social.name}
						</a>
					))
				}
			</div>
		</div>

		<p class="meta-mono mt-7">© {year} Sudhir · Information Security · Mumbai, India</p>
	</footer>
</Section>
