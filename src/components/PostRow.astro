---
import type { SitePost } from '@/utils/posts';

interface Props {
	post: SitePost;
}

const { post } = Astro.props;
const { data, url } = post;
const isPinned = data.isPinned === true;
const isoDate = data.pubDate.toISOString().slice(0, 10);

const MONTHS = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
const displayDate = `${String(data.pubDate.getUTCDate()).padStart(2, '0')}-${MONTHS[data.pubDate.getUTCMonth()]}-${String(data.pubDate.getUTCFullYear()).slice(-2)}`;

const tags = (data.tags ?? []).slice(0, 3);
---

<a href={url} class="group relative block" aria-label={`Read post: ${data.title}`}>
	<span
		class="bg-accent-strong absolute inset-y-3 left-0 w-0.5 origin-center scale-y-0 rounded-full transition-transform duration-200 group-hover:scale-y-100"
	></span>
	<div
		class="border-line group-hover:bg-surface-2/60 border-b px-4 py-5 transition-colors md:px-6 sm:grid sm:grid-cols-[6.5rem_minmax(0,1fr)_auto] sm:items-baseline sm:gap-x-6"
	>
		<time datetime={isoDate} class="text-faint block font-mono text-xs tracking-tight tabular-nums sm:pt-1">
			{displayDate}
		</time>

		<div class="mt-2 min-w-0 sm:mt-0">
			<div class="flex flex-wrap items-baseline gap-x-2.5 gap-y-1">
				{isPinned && (
					<span class="text-accent font-mono text-[0.65rem] font-medium uppercase tracking-wider">
						Pinned
					</span>
				)}
				<h2
					transition:name={`post-title-${post.slug}`}
					class="font-display text-fg group-hover:text-accent text-lg font-semibold leading-snug tracking-tight transition-colors"
				>
					{data.title}
				</h2>
			</div>
			<p class="text-muted mt-1.5 line-clamp-1 text-sm">{data.excerpt}</p>
			{tags.length > 0 && (
				<div class="text-faint mt-2 flex flex-wrap gap-x-3 font-mono text-[0.7rem]">
					{tags.map((t: string) => (
						<span><span class="opacity-60">#</span>{t}</span>
					))}
				</div>
			)}
		</div>

		<span class="text-faint mt-3 block font-mono text-xs tabular-nums sm:mt-0 sm:pt-1 sm:text-right">
			{data.minutesRead ?? 'Quick read'}
		</span>
	</div>
</a>
