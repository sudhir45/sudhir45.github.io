---
import type { SitePost } from '@/utils/posts';

interface Props {
	post: SitePost;
	/** The lead row gets the single amber "Read →"; the rest stay muted. */
	accent?: boolean;
	last?: boolean;
}

const { post, accent = false, last = false } = Astro.props as Props;

const monthYear = post.data.pubDate.toLocaleDateString('en-US', {
	month: 'short',
	year: 'numeric'
});
---

<a
	href={post.url}
	class:list={[
		'row-link grid grid-cols-[64px_1fr] items-baseline gap-x-5 gap-y-1 py-6 sm:grid-cols-[96px_1fr_auto] sm:gap-6',
		!last && 'border-line border-b'
	]}
>
	<span class="meta-mono order-1 sm:order-none">{monthYear}</span>
	<span class="order-3 col-span-2 sm:order-none sm:col-span-1">
		<span class="row-title font-display text-fg block text-[19px] font-medium leading-[1.3] tracking-[-0.01em] transition-colors sm:text-[21px]">
			{post.data.title}
		</span>
		<span class="text-faint mt-1.5 block text-[15px] leading-[1.55]">
			{post.data.description}
		</span>
	</span>
	<span
		class:list={[
			'order-2 justify-self-end text-[13px] font-medium sm:order-none',
			accent ? 'text-accent' : 'text-faint'
		]}
	>
		Read <span class="row-arrow">→</span>
	</span>
</a>
