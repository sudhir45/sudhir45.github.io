---
import Section from './Section.astro';
import { getAllPosts } from '@/utils/posts';

const allPosts = await getAllPosts();
const pinnedPost = allPosts.find((p) => p.data.isPinned);
const featuredPost = pinnedPost ?? allPosts[0];

const meta = featuredPost?.data;
---

{featuredPost && (
	<Section>
		<div class="animate-fade-up stagger-2 mb-2 mt-4">
			<div class="flex items-center gap-2.5 mb-5">
				<span class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-zinc-400 dark:text-zinc-500">Featured</span>
				<div class="h-px flex-1 bg-zinc-200/70 dark:bg-zinc-800/70"></div>
			</div>

			<a
				href={featuredPost.url}
				class="group block rounded-xl border-l-[3px] border-blue-500 bg-zinc-50/80 py-6 pl-6 pr-6 transition-all duration-200 hover:bg-zinc-100/80 dark:bg-zinc-900/60 dark:hover:bg-zinc-800/60"
			>
				<h3 class="text-xl font-semibold leading-snug text-zinc-900 transition-colors group-hover:text-blue-600 dark:text-zinc-100 dark:group-hover:text-blue-400 md:text-2xl">
					{meta.title}
				</h3>
				<p class="mt-2.5 max-w-2xl text-[0.925rem] leading-relaxed text-zinc-600 dark:text-zinc-400">
					{meta.excerpt}
				</p>
				<div class="mt-4 flex items-center gap-3 text-sm text-zinc-500 dark:text-zinc-500">
					<span class="font-medium">{meta.minutesRead ?? '6 min read'}</span>
					<span class="text-zinc-300 dark:text-zinc-700">·</span>
					<span class="inline-flex items-center gap-1 font-medium text-blue-600 transition-all group-hover:gap-2 dark:text-blue-400">
						Read post
						<svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
						</svg>
					</span>
				</div>
			</a>
		</div>
	</Section>
)}
