---
import Section from './Section.astro';
import { formatDate } from '@/utils/data.util';
import { getAllPosts } from '@/utils/posts';

const allPosts = await getAllPosts();
const pinnedPost = allPosts.find((p) => p.data.isPinned);
const featuredPost = pinnedPost ?? allPosts[0];

const meta = featuredPost?.data;
---

{featuredPost && (
	<Section>
		<div class="animate-fade-up stagger-2 mb-2 mt-6">
			<div class="mb-5 flex items-center gap-3">
				<span class="eyebrow eyebrow-tick">Featured</span>
				<div class="bg-line h-px flex-1"></div>
			</div>

			<a
				href={featuredPost.url}
				class="group bg-surface border-line hover:border-accent/40 relative block overflow-hidden rounded-xl border p-6 transition-colors duration-200 sm:p-7"
			>
				<span class="bg-accent-strong absolute inset-y-0 left-0 w-[3px]"></span>

				<div class="eyebrow text-faint mb-3 flex items-center gap-2">
					<time>{formatDate(meta.pubDate)}</time>
					<span aria-hidden="true">·</span>
					<span>{meta.minutesRead ?? 'Quick read'}</span>
				</div>

				<h3 class="font-display text-fg group-hover:text-accent text-xl font-semibold leading-snug tracking-tight transition-colors md:text-2xl">
					{meta.title}
				</h3>
				<p class="text-muted mt-2.5 max-w-2xl text-[0.95rem] leading-relaxed">
					{meta.excerpt}
				</p>
				<span class="text-accent mt-4 inline-flex items-center gap-1 text-sm font-medium transition-all group-hover:gap-2">
					Read post
					<svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
					</svg>
				</span>
			</a>
		</div>
	</Section>
)}
