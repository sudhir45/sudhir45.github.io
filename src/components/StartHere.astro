---
import Section from './Section.astro';
import { getPostBySlug } from '@/utils/posts';

// Hand-picked evergreen posts that show the range of the blog.
export const START_HERE_SLUGS = [
	'security-architecture-fundamentals',
	'good-enough-security',
	'prompt-injection-llm-security'
];

const hooks: Record<string, string> = {
	'security-architecture-fundamentals': 'Security architecture',
	'good-enough-security': 'Security strategy',
	'prompt-injection-llm-security': 'AI security'
};

const picks = (
	await Promise.all(START_HERE_SLUGS.map(async (slug) => await getPostBySlug(slug)))
).filter((post) => post !== undefined);
---

{
	picks.length > 0 && (
		<Section>
			<div class="animate-fade-up stagger-3 mb-2 mt-8">
				<div class="mb-2 flex items-center gap-3">
					<span class="eyebrow eyebrow-tick">Start here</span>
					<div class="bg-line h-px flex-1" />
				</div>
				<p class="text-muted mb-6 text-sm">
					Three posts that cover the core of what I write about.
				</p>

				<div class="grid grid-cols-1 gap-5 md:grid-cols-3">
					{picks.map((post) => (
						<a
							href={post.url}
							class="group bg-surface border-line hover:border-accent/40 flex flex-col rounded-xl border p-5 transition-all duration-200 hover:-translate-y-0.5"
						>
							<span class="text-accent font-mono text-[0.7rem] font-medium uppercase tracking-[0.14em]">
								{hooks[post.slug] ?? 'Read this'}
							</span>
							<h3
								transition:name={`post-title-${post.slug}`}
								class="font-display text-fg group-hover:text-accent mt-2.5 text-base font-semibold leading-snug tracking-tight transition-colors"
							>
								{post.data.title}
							</h3>
							<span class="text-faint mt-auto pt-4 font-mono text-xs tabular-nums">
								{post.data.minutesRead ?? 'Quick read'}
							</span>
						</a>
					))}
				</div>
			</div>
		</Section>
	)
}
